# Optional site overrides. Copy to production.env in this directory.
#
# Standard layout (sibling repos):
#   Documents/
#     Meld_Hippunfold/     ← this pipeline
#     Meld_Graph/docker_version/   ← meld-docker + licenses + models
#     HippUnfold/          ← run_hippunfold.sh + pull_sif.sh
#
# export MELD_DEPLOY_ROOT=/path/to/Meld_Graph/docker_version
# export HIPPUNFOLD_ROOT=/path/to/HippUnfold
# export MELD_IMAGE_TAG=v2.2.4
# export HIPPUNFOLD_IMAGE_TAG=latest
#
# export HIPPUNFOLD_CACHE_DIR=/scratch/$USER/hippunfold_cache
# export SNAKEMAKE_LATENCY_WAIT=120
#
# SLURM (edit slurm_meldhip.slurm or override at submit time)
# export SLURM_PARTITION=general
# export SLURM_MEM=64G
